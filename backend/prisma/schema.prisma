generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  SUPER_ADMIN
  CABINET_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum LocationStatus {
  ACTIVE
  INACTIVE
}

enum CabinetStatus {
  ACTIVE
  INACTIVE
  OFFLINE
}

enum CompartmentSize {
  SMALL
  LARGE
}

enum CompartmentAvailability {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
  RESERVED
}

enum LockStatus {
  UNKNOWN
  LOCKED
  UNLOCKED
  FAULTY
}

enum DoorStatus {
  CLOSED
  OPEN
  UNKNOWN
}

enum RentalType {
  ONCE
  DAILY
  MONTHLY
}

enum RentalStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum PaymentMethod {
  MOMO
  ZALOPAY
  VIETQR
  CASH
  NONE
}

enum LockerAction {
  OPENED
  CLOSED
  EXPIRED
  DENIED
  NO_SHOW
  HEARTBEAT
  FAULTY
}

enum AuditAction {
  LOGIN
  LOGOUT
  CREATE_LOCATION
  UPDATE_LOCATION
  DELETE_LOCATION
  CREATE_CABINET
  UPDATE_CABINET
  DELETE_CABINET
  UNLOCK_COMPARTMENT
  CANCEL_RENTAL
}

enum NotificationType {
  RENTAL_EXPIRED
  CABINET_OFFLINE
  RENTAL_STARTED
  PAYMENT_SUCCESS
  RENTAL_EXPIRING_SOON
  SYSTEM
}

enum DeviceType {
  ANDROID
  WEB
  KIOSK
}

model Admin {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         AdminRole @default(CABINET_ADMIN)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  auditLogs    AuditLog[]
}

model User {
  id            String         @id @default(cuid())
  email         String?        @unique
  phone         String         @unique
  passwordHash  String?
  name          String?
  status        UserStatus     @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  rentals       Rental[]
  notifications Notification[]
  sessions      UserSession[]

  @@index([phone])
  @@index([email])
}

model Location {
  id            String         @id @default(cuid())
  name          String
  address       String
  latitude      Float?
  longitude     Float?
  googlePlaceId String?        @unique
  mapImageUrl   String?
  status        LocationStatus @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  cabinets      Cabinet[]

  @@index([status])
}

model Cabinet {
  id              String        @id @default(cuid())
  locationId      String
  name            String
  status          CabinetStatus @default(ACTIVE)
  lastHeartbeatAt DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  location        Location      @relation(fields: [locationId], references: [id])
  compartments    Compartment[]
  mcpDevices      McpDevice[]
  logs            LockerLog[]

  @@index([locationId])
  @@index([status])
}

model McpDevice {
  id                 String        @id @default(cuid())
  cabinetId          String
  bus                Int           @default(1)
  address            Int           @default(32)
  name               String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  cabinet            Cabinet       @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  lockCompartments   Compartment[] @relation("LockMcp")
  sensorCompartments Compartment[] @relation("SensorMcp")

  @@unique([cabinetId, bus, address])
  @@index([cabinetId])
}

model Compartment {
  id                String                  @id @default(cuid())
  cabinetId         String
  name              String
  size              CompartmentSize
  mcp23017PinLock   Int
  mcp23017PinSensor Int
  lockMcpDeviceId   String?
  sensorMcpDeviceId String?
  status            CompartmentAvailability @default(AVAILABLE)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  cabinet           Cabinet                 @relation(fields: [cabinetId], references: [id])
  lockMcpDevice     McpDevice?              @relation("LockMcp", fields: [lockMcpDeviceId], references: [id], onDelete: SetNull)
  sensorMcpDevice   McpDevice?              @relation("SensorMcp", fields: [sensorMcpDeviceId], references: [id], onDelete: SetNull)
  rentals           Rental[]
  logs              LockerLog[]
  realtimeStatus    CompartmentStatus?

  @@unique([cabinetId, name])
  @@index([cabinetId])
  @@index([lockMcpDeviceId])
  @@index([sensorMcpDeviceId])
  @@index([status])
}

model CompartmentStatus {
  id             String      @id @default(cuid())
  compartmentId  String      @unique
  lockStatus     LockStatus  @default(UNKNOWN)
  doorStatus     DoorStatus  @default(UNKNOWN)
  lastUpdatedAt  DateTime    @default(now())
  compartment    Compartment @relation(fields: [compartmentId], references: [id], onDelete: Cascade)

  @@index([lockStatus])
  @@index([doorStatus])
}

model PricePlan {
  id           String          @id @default(cuid())
  name         String
  size         CompartmentSize
  rentalType   RentalType
  price        Int
  maxOpens     Int?
  durationDays Int
  description  String?
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  rentals      Rental[]

  @@index([size, isActive])
  @@index([rentalType])
}

model Rental {
  id            String        @id @default(cuid())
  userId        String?
  compartmentId String
  pricePlanId   String
  code          String        @unique
  codeHash      String
  qrToken       String        @unique
  openCount     Int           @default(0)
  maxOpens      Int
  expiresAt     DateTime
  paymentStatus PaymentStatus @default(PENDING)
  paymentMethod PaymentMethod @default(NONE)
  paidAt        DateTime?
  status        RentalStatus  @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User?         @relation(fields: [userId], references: [id])
  compartment   Compartment   @relation(fields: [compartmentId], references: [id])
  pricePlan     PricePlan     @relation(fields: [pricePlanId], references: [id])
  logs          LockerLog[]

  @@index([code])
  @@index([qrToken])
  @@index([userId])
  @@index([compartmentId])
  @@index([status])
  @@index([expiresAt])
}

model LockerLog {
  id            String       @id @default(cuid())
  cabinetId     String?
  compartmentId String?
  rentalId      String?
  action        LockerAction
  attemptCount  Int          @default(0)
  success       Boolean
  ipAddress     String?
  deviceInfo    String?
  note          String?
  createdAt     DateTime     @default(now())
  cabinet       Cabinet?     @relation(fields: [cabinetId], references: [id])
  compartment   Compartment? @relation(fields: [compartmentId], references: [id])
  rental        Rental?      @relation(fields: [rentalId], references: [id])

  @@index([compartmentId])
  @@index([cabinetId])
  @@index([rentalId])
  @@index([action])
  @@index([createdAt])
}

model AuditLog {
  id         String      @id @default(cuid())
  adminId    String
  action     AuditAction
  resource   String
  resourceId String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime    @default(now())
  admin      Admin       @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String?
  title     String
  body      String
  type      NotificationType
  data      Json?
  isRead    Boolean          @default(false)
  sentAt    DateTime         @default(now())
  createdAt DateTime         @default(now())
  user      User?            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([type])
}

model UserSession {
  id             String     @id @default(cuid())
  userId         String
  socketId       String     @unique
  deviceType     DeviceType
  deviceInfo     String?
  connectedAt    DateTime   @default(now())
  disconnectedAt DateTime?
  isActive       Boolean    @default(true)
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([socketId])
}
