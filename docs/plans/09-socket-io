## Implementation

```typescript
// backend/src/lib/socket.ts
import { Server, Socket } from 'socket.io';
import { verifyToken } from './jwt';
import type { JwtPayload } from './jwt';

function extractToken(handshake: Socket['handshake']): string | null {
  // 1. Try socket.io native auth field
  const authToken = handshake.auth?.token as string | undefined;
  if (authToken) return authToken;

  // 2. Fallback: Authorization header
  const authHeader = handshake.headers?.authorization;
  if (authHeader?.startsWith('Bearer ')) {
    return authHeader.slice(7);
  }

  return null;
}

export function initSocket(httpServer: HttpServer): Server {
  io = new Server(httpServer, {
    cors: { origin: process.env.CORS_ORIGIN || '*', methods: ['GET', 'POST', 'PUT', 'DELETE'] },
  });

  // Auth middleware — runs before 'connection' event
  io.use((socket: Socket, next) => {
    const token = extractToken(socket.handshake);
    if (!token) {
      return next(new Error('Authentication error: No token provided'));
    }

    try {
      const payload = verifyToken(token, process.env.JWT_SECRET || '') as JwtPayload;
      if (!payload.sub || !payload.role) {
        return next(new Error('Authentication error: Invalid token payload'));
      }
      if (!['ADMIN', 'SUPER_ADMIN'].includes(payload.role)) {
        return next(new Error('Authorization error: Admin role required'));
      }
      socket.data.admin = payload;
      next();
    } catch {
      next(new Error('Authentication error: Invalid or expired token'));
    }
  });

  io.on('connection', (socket: Socket) => {
    socket.on('cabinet:join', (cabinetId: string) => {
      socket.join(`cabinet:${cabinetId}`);
    });
  });

  return io;
}
```

**On the client side** (admin dashboard), connecting will look like:
```typescript
const socket = io(SOCKET_URL, {
  auth: { token: adminAccessToken }
});
```

Socket.IO will automatically pass `auth.token` in the handshake.

