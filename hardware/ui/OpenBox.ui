  <property name="styleSheet">
   <string notr="true">/* ===== ROOT ===== */
QWidget#Form {
    background-color: #000000;
    color: #F2F2F2;
    font-family: &quot;Segoe UI&quot;;
}

/* ===== 2 CARD CHÍNH ===== */
QFrame#frameStatusCard,
QFrame#frameTimerCard {
    background: qlineargradient(
        x1: 0, y1: 0, x2: 1, y2: 1,
        stop: 0 #1A1A1F,
        stop: 1 #131318
    );
    border: none;
    border-radius: 22px;
}

/* ===== CARD TRẠNG THÁI ===== */
QLabel#labelStatusTitle {
    background: transparent;
    color: #E9A889;
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 2px;
}

QLabel#labelBoxName {
    background: transparent;
    color: #FFFFFF;
    font-size: 30px;
    font-weight: 800;
}

QLabel#labelBoxState {
    background: transparent;
    color: #F2A07D;
    font-size: 20px;
    font-weight: 700;
}

QLabel#labelInstruction {
    background: transparent;
    color: #F4A07A;
    font-size: 18px;
    font-weight: 800;
}

/* ===== ICON BOX ===== */
QFrame#frame_3 {
    background: rgba(255, 255, 255, 0.05);
    border: none;
    border-radius: 16px;
}

QFrame#frame_3 QLabel#label {
    background: transparent;
    color: #F2A886;
    border: none;
}

/* ===== CARD THỜI GIAN ===== */
QLabel#labelTimerTitle {
    background: transparent;
    color: #E3A487;
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 2px;
}

/* bỏ toàn bộ border phần thời gian */
QLabel#labelTimerValue,
QLabel#labelTimerUnit {
    background: transparent;
    border: none;
    outline: none;
    color: #FF7A00;
}

QLabel#labelTimerValue {
    font-size: 56px;
    font-weight: 900;
}

QLabel#labelTimerUnit {
    font-size: 24px;
    font-weight: 800;
    padding-left: 2px;
}

/* nếu cái viền cam vẫn còn do label auto selected/focus */
QLabel#labelTimerTitle,
QLabel#labelTimerValue,
QLabel#labelTimerUnit {
    selection-background-color: transparent;
    selection-color: inherit;
}

/* ===== BUTTON COMPLETE ===== */
QPushButton#btnComplete {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:0,
        stop:0 #F0B08D,
        stop:1 #FF7A00
    );
    color: #4B210F;
    border: none;
    border-radius: 18px;
    font-size: 24px;
    font-weight: 900;
    padding-left: 22px;
    padding-right: 22px;
    text-align: center;

}

QPushButton#btnComplete:hover {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:0,
        stop:0 #F6BC9C,
        stop:1 #FF8D23
    );
}

QPushButton#btnComplete:pressed {
    background: #E56D00;
    color: #3A170A;
}</string>
