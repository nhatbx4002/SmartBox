  <property name="styleSheet">
   <string notr="true">QWidget#Form {
    background-color: #070707;
    color: #F3EEEA;
    font-family: &quot;Segoe UI&quot;;
}

/* ===== Title ===== */
QLabel#labelTitle {
    background: transparent;
    color: #F2ECE7;
    font-size: 25px;
    font-weight: 800;
    qproperty-alignment: AlignCenter;
}

/* ===== Card ===== */
QFrame#formCard {
    background-color: rgba(34, 26, 24, 0.92);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 20px;
}

/* ===== Label nhỏ ===== */
QLabel#labelTitleCard {
    background: transparent;
    color: #B69080;
    font-weight: 700;
}

/* ===== Input container ===== */
QFrame#frame {
    background-color: #3A3938;
    border: none;
    border-bottom: 3px solid #FF6A00;
    border-radius: 14px;
}

/* ===== Input text ===== */
QLineEdit#input {
    background: transparent;
    border: none;
    color: #F7F3F0;
    font-weight: 800;
    padding-left: 12px;
    selection-background-color: #FF6A00;
}

/* focus nhẹ */
QLineEdit#input:focus {
    color: #FFFFFF;
}

/* placeholder */
QLineEdit#input::placeholder {
    color: rgba(255,255,255,0.35);
}

/* ===== Button ===== */
QPushButton#btnConfirm {
    background-color: qlineargradient(
        x1:0, y1:0, x2:1, y2:0,
        stop:0 #F3B294,
        stop:1 #FF7200
    );
    color: #2A140B;
    border: none;
    border-radius: 14px;
    font-weight: 900;
}

/* hover */
QPushButton#btnConfirm:hover {
    background-color: qlineargradient(
        x1:0, y1:0, x2:1, y2:0,
        stop:0 #F7B99D,
        stop:1 #FF7C14
    );
}

/* pressed */
QPushButton#btnConfirm:pressed {
    background-color: qlineargradient(
        x1:0, y1:0, x2:1, y2:0,
        stop:0 #E6A88A,
        stop:1 #E56700
    );
}</string>
