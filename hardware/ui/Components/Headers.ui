    font-weight: 600;
}

/* SYSTEM text */
#labelSystem {
    color: #ff6a00;
    font-size: 18px;
    font-weight: bold;
    letter-spacing: 2px;
}

/* Time */
#labelTime{
    color: #ffffff;
    font-size: 18px;
    font-weight: 500;
}

/* Optional: icon bên trái */
#iconApp {
    background: transparent;
}</string>
