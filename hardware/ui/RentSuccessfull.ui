  <property name="styleSheet">
   <string notr="true">#RentSuccessfull {background-color: black}

QLabel#labelTitle {
    color: #F3F1F1;
    font-size: 28px;
    font-weight: 800;
    background: transparent;
}

QLabel#labelSubtitle {
    color: #D8B7A7;
    font-size: 16px;
    font-weight: 600;
    background: transparent;
}

QFrame#pinFrame {
    background-color: #232327;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 18px;
}

QLabel#labelTitlePin {
    color: #E0B9A5;
    font-size: 14px;
    font-weight: 700;
    background: transparent;
}

QLabel#labelPinShow {
    color: #FF7A00;
    font-size: 42px;
    font-weight: 900;
    background: transparent;
}
QPushButton#useLater {
    background-color: #2D2D31;
    color: #F2B18A;
    border: 1px solid rgba(255, 122, 0, 0.55);
    border-radius: 14px;
    font-size: 16px;
    font-weight: 700;
    padding: 10px 18px;
    text-align: center;
}

QPushButton#useLater:hover {
    background-color: #35353A;
    border: 1px solid rgba(255, 122, 0, 0.8);
}

QPushButton#useLater:pressed {
    background-color: #252529;
    border: 1px solid rgba(255, 122, 0, 0.95);
}

QPushButton#useLater:disabled {
    background-color: #242428;
    color: rgba(242, 177, 138, 0.45);
    border: 1px solid rgba(255, 122, 0, 0.2);
}


QPushButton#useNow {
    background-color: #45C96F;
    color: #FFFFFF;
    border: none;
    border-radius: 14px;
    font-size: 16px;
    font-weight: 800;
    padding: 10px 18px;
    text-align: center;
}

QFrame#IconBox {
    background-color: rgba(7, 24, 18, 0.85);
    border: 2px solid rgba(40, 180, 110, 0.35);
    border-radius: 20px;
}


QPushButton#useNow:hover {
    background-color: #52D97D;
}

QPushButton#useNow:pressed {
    background-color: #38B862;
}

QPushButton#useNow:disabled {
    background-color: #2E7F49;
    color: rgba(255, 255, 255, 0.5);
}</string>
