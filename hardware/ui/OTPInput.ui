   <string notr="true">#OTPInput{
    background: #0A0A0A;
}
#labelTitle {
    color: #D8D3D1;
    font-size: 30px;
    font-weight: 700;
    font-family: &quot;Segoe UI&quot;;
    background: transparent;
}
#pinRowFrame {
    background: transparent;
}
#digit1, #digit2, #digit3, #digit4, #digit5, #digit6 {
    background-color: rgba(52, 52, 52, 0.88);
    border: 1px solid rgba(255, 176, 137, 0.16);
    border-radius: 12px;
    color: #FFB08A;
    font-size: 34px;
    font-weight: 700;
    font-family: &quot;Segoe UI&quot;;
}
#btnConfirm {
    background-color: qlineargradient(
        x1:0, y1:0, x2:1, y2:0,
        stop:0 #FF7A1A,
        stop:1 #F5B08D
    );
    border: none;
    border-radius: 16px;
    color: #2A1A12;
    font-size: 18px;
    font-weight: 700;
    font-family: &quot;Segoe UI&quot;;
    padding: 8px 20px;
}

#btnConfirm:hover {
    background-color: qlineargradient(
        x1:0, y1:0, x2:1, y2:0,
        stop:0 #FF8A32,
        stop:1 #F7BA9B
    );
}

#btnConfirm:pressed {
    padding-top: 10px;
    padding-bottom: 6px;
}</string>
