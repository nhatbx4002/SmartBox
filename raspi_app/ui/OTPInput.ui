    background-color: #1C1B1B;
    border: 2px solid #333333;
    border-radius: 24px;
}

QLabel#labelOtpTitle {
    background: transparent;
    color: #FFFFFF;
    font-size: 22px;
    font-weight: 900;
    letter-spacing: 2px;
}
QLineEdit {
    background-color: #2A2A2A;
    border: 2px solid #333333;
    border-radius: 12px;
    color: #FFFFFF;
    font-size: 36px;
    font-weight: 900;
    font-family: &quot;Be Vietnam Pro&quot;;
    padding: 0px;
}

QLineEdit:focus {
    border: 2px solid #FF6600;
}

QPushButton {
    background-color: #1C1C1C;
    border: 2px solid #333333;
    border-radius: 40px;
    color: #E8E8E8;
    font-size: 32px;
    font-weight: 900;
}

QPushButton:pressed {
    background-color: #333333;
    border-color: #FF6600;
}

QPushButton#btnClear {
    font-size: 20px;
}
QPushButton#btnConfirm {
    background-color: #FF6600;
    border: none;
    border-radius: 14px;
    color: #1A1A1A;
    font-size: 24px;
    font-weight: 900;
    letter-spacing: 4px;
}

QPushButton#btnConfirm:pressed {
    background-color: #E85C00;
}</string>
