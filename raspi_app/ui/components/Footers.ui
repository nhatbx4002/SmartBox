  <property name="styleSheet">
   <string notr="true">/* =========================
   SMARTBOX FOOTER COMPONENT
   ========================= */

#DashboardFooterFrame {
    background-color: #0A0A0A;
    border-top: 2px solid #333333;
}

#FooterVersionLabel {
    background-color: transparent;
    border: none;
    color: #B0B0B0;

    font-family: &quot;Be Vietnam Pro&quot;, &quot;Arial&quot;, sans-serif;
    font-size: 12px;
    font-weight: 700;
}

#FooterStatusDot {
    background-color: #00FF41;
    border: none;
    border-radius: 4px;
}

#FooterStatusLabel {
    background-color: transparent;
    border: none;
    color: #00FF41;

    font-family: &quot;Be Vietnam Pro&quot;, &quot;Arial&quot;, sans-serif;
    font-size: 12px;
    font-weight: 700;
}</string>
