  <property name="styleSheet">
   <string notr="true">#mainContent {
    background-color: #050505;
    border: none;
}

QPushButton#btnBack {
    background-color: #101010;
    border: 1px solid #333333;
    border-radius: 12px;
    color: #FFFFFF;
    font-family: &quot;Be Vietnam Pro&quot;, &quot;Segoe UI&quot;;
    font-size: 18px;
    font-weight: 800;
    text-align: center;
    padding: 0px;
}

QPushButton#btnBack:pressed {
    background-color: #1C1C1C;
    border: 1px solid #FF6600;
    color: #FF6600;
}

QFrame#totalCard {
    background-color: #101010;
    border: 2px solid #333333;
    border-radius: 20px;
}

QLabel#lblTotalTitle {
    color: #8E8E8E;
    font-size: 20px;
    font-weight: 900;
    background-color: transparent;
}

QLabel#lblAmount {
    color: #FF6600;
    font-size: 64px;
    font-weight: 900;
    background-color: transparent;
}

QLabel#lblPlanInfo {
    color: #BDBDBD;
    font-size: 18px;
    font-weight: 600;
    background-color: transparent;
}

QLabel#lblPaymentMethodTitle {
    color: #8E8E8E;
    font-size: 17px;
    font-weight: 900;
    background-color: transparent;
}

QPushButton#btnPaymentMomo,
QPushButton#btnPaymentZalo,
QPushButton#btnPaymentVietQR {
    background-color: #101010;
    border: 1px solid #333333;
    border-radius: 14px;
}

QPushButton#btnPaymentMomo[selected=&quot;true&quot;],
QPushButton#btnPaymentZalo[selected=&quot;true&quot;],
QPushButton#btnPaymentVietQR[selected=&quot;true&quot;] {
    background-color: #1C1C1C;
    border: 2px solid #FF6600;
    border-radius: 14px;
}

QLabel#lblMomoText,
QLabel#lblZaloText,
QLabel#lblVietQrText {
    color: #FFFFFF;
    font-family: &quot;Be Vietnam Pro&quot;, &quot;Segoe UI&quot;;
    font-size: 22px;
    font-weight: 700;
    background-color: transparent;
}

QPushButton#btnPayNow {
    background-color: #2E7D32;
    border: none;
    border-radius: 14px;
    color: #FFFFFF;
    font-size: 25px;
    font-weight: 900;
}

QPushButton#btnPayNow:pressed {
    background-color: #256B2A;
}

QPushButton#btnPayNow:disabled {
    background-color: #1E3F22;
    color: #777777;
}
</string>
